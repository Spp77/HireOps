# ═══════════════════════════════════════════════════════════════
#  HireOps — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────────
# development | production | test
ENV=development


# ── Django Core ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── PostgreSQL Database ────────────────────────────────────────
# Primary (read + write)
DB_NAME=hireops
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Optional read replica (horizontal DB scaling)
# Leave empty to disable read/write splitting.
DB_READ_HOST=
DB_READ_PORT=5432


# ── Redis ──────────────────────────────────────────────────────
# Used for: cache, sessions, Celery broker + result backend
REDIS_URL=redis://localhost:6379/0


# ── Celery ─────────────────────────────────────────────────────
# Defaults to REDIS_URL if not set separately
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7


# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173


# ── Email (SMTP) ───────────────────────────────────────────────
# In development, console backend is used by default.
# In production, configure your SMTP provider here.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=HireOps <noreply@hireops.com>


# ── Gunicorn (production) ──────────────────────────────────────
# Workers = (2 × CPU) + 1 by default. Override here.
GUNICORN_WORKERS=5
GUNICORN_THREADS=2
GUNICORN_LOG_LEVEL=info


# ── Cloud Storage (future — uncomment when ready) ──────────────
# When you're ready to store uploads in S3 / GCS instead of disk:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=hireops-media
# AWS_S3_REGION_NAME=us-east-1
# DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage
